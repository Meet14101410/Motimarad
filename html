<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Moti Marad - Village Profile</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #fdf2f2; display: flex; justify-content: center; padding: 40px; }
        .village-card { background: white; width: 420px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border-top: 6px solid #c0392b; overflow: hidden; }
        .header { padding: 20px; background: #fff5f5; text-align: center; }
        .details { padding: 25px; color: #2c3e50; }
        .info-row { display: flex; justify-content: space-between; margin-bottom: 12px; border-bottom: 1px solid #f1f1f1; padding-bottom: 8px; }
        .label { font-weight: bold; color: #c0392b; }
        .value { font-weight: 500; }
    </style>
</head>
<body>
    <div class="village-card">
        <div class="header"><h1>🏡 Moti Marad</h1><p>Rajkot, Gujarat</p></div>
        <div class="details">
            <div class="info-row"><span class="label">Taluka:</span><span class="value">Dhoraji</span></div>
            <div class="info-row"><span class="label">District:</span><span class="value">Rajkot</span></div>
            <div class="info-row"><span class="label">Pincode:</span><span class="value">360410</span></div>
            <div class="info-row"><span class="label">Primary Sector:</span><span class="value">Agriculture</span></div>
            <div class="info-row"><span class="label">Region:</span><span class="value">Saurashtra</span></div>
        </div>
    </div>
</body>
</html>
